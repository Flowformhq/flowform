# Production environment variables for FlowForm engine
# Copy this to .env and fill in real values
# NEVER commit .env to git

APP_NAME=FlowForm
APP_ENV=production
APP_DEBUG=false
APP_URL=https://demo.flowformhq.com
APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=flowform
DB_USERNAME=flowform
DB_PASSWORD=

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379

LOG_CHANNEL=stderr
LOG_LEVEL=warning

FLOWFORM_TELEMETRY_ENABLED=true
FLOWFORM_TELEMETRY_URL=https://telemetry.flowformhq.com/ping

# Social login (fill in after registering apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
